///////////////////////
// UTILS & TYPES
///////////////////////

type GeoPoint = { lat: number; lon: number };
type UserID = string;
type MICs = number;

export interface LiveEvent {
  id: string;
  userId: UserID;
  videoUrl: string;
  geo: GeoPoint;
  timestamp: number;
  archivedOnChainUrl?: string;
  trustScore?: number;
}

export interface ARInfo {
  eventId: string;
  overlay: string;
  timeline: string[];
  safetyTips: string;
}

export interface CommunityPost {
  id: string;
  userId: UserID;
  text: string;
  timestamp: number;
  sentiment?: number;
}

export interface Badge {
  id: string;
  name: string;
  description?: string;
  date: number;
}

export interface WearableSnapshot {
  userId: UserID;
  stress: number;
  sleep: number;
  activity: number;
  time: number;
}

export interface SkillNode {
  id: string;
  name: string;
  children?: SkillNode[];
  badge?: Badge;
}

export interface PeerReview {
  reviewerId: UserID;
  feedback: string;
  approved: boolean;
  timestamp: number;
}

export interface MicroTask {
  id: string;
  type: string;
  location: GeoPoint;
  reward: MICs;
  status: 'open' | 'in-progress' | 'done';
  assignedTo?: UserID;
}

export interface Resource {
  id: string;
  type: string;
  name: string;
  location: GeoPoint;
  verified: boolean;
  updated: number;
}

export interface SkillListing {
  id: string;
  userId: UserID;
  skill: string;
  price: MICs;
  reputation: number;
  available: boolean;
}

export interface WhatIfScenario {
  id: string;
  scenarioType: string;
  parameters: Record<string, any>;
  result: string;
  projectedImpact: string;
}

